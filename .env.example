# AI Provider Configuration for Car Research
# Copy this file to .env and fill in your API key

# AI Provider: openai, anthropic, zai, or custom
VITE_AI_PROVIDER=openai

# API Key for the selected provider
VITE_AI_API_KEY=your_api_key_here

# Optional: Custom API endpoint (uses provider default if not specified)
# For production, set up a proxy server and set VITE_AI_ENDPOINT to your proxy URL.
# Your proxy should forward requests to the AI API with proper headers.
# VITE_AI_ENDPOINT=https://your-proxy.com/api/research

# Optional: Z.ai model name (default: glm-5)
# VITE_ZAI_MODEL=glm-5

# NOTE: A Vite proxy is configured for development mode (npm run dev).
# This bypasses CORS issues by routing requests through the dev server.
# For production builds, you MUST set up a server-side proxy and use VITE_AI_ENDPOINT.
